{
  "name": "srgnt",
  "version": "0.0.0",
  "private": true,
  "description": "Desktop-first personal command center",
  "license": "SEE LICENSE IN LICENSE.md",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @srgnt/desktop test:e2e",
    "test:e2e:packaged:linux": "pnpm --filter @srgnt/desktop test:e2e:packaged:linux",
    "cli:connectors": "pnpm --filter @srgnt/desktop cli:connectors",
    "build": "pnpm -r build",
    "release:check:repo": "pnpm --filter @srgnt/desktop build:icons && pnpm run --filter @srgnt/desktop pack && pnpm test && pnpm test:e2e && pnpm test:e2e:packaged:linux",
    "release:artifacts:linux": "pnpm --filter @srgnt/desktop dist:linux && pnpm --filter @srgnt/desktop dist:rpm:fedora",
    "release:rc:linux": "pnpm run release:check:repo && pnpm run release:artifacts:linux"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild@0.21.5": "0.25.0",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4"
    },
    "patchedDependencies": {
      "@codemirror/view@6.41.0": "patches/@codemirror__view@6.41.0.patch"
    }
  }
}
