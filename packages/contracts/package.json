{
  "name": "@srgnt/contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Shared contracts and entity schemas for srgnt",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./entities": {
      "types": "./dist/entities/index.d.ts",
      "default": "./dist/entities/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@effect/schema": "^0.75.5",
    "effect": "^3.21.0",
    "fast-check": "^4.6.0",
    "pure-rand": "^8.4.0"
  },
  "devDependencies": {
    "@srgnt/tsconfig": "workspace:*",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
