{
  "manifest": {
    "id": "jira",
    "name": "Jira",
    "version": "0.1.0",
    "description": "Atlassian Jira connector — standalone package (Phase 21)",
    "provider": "atlassian",
    "authType": "oauth2",
    "config": {
      "authType": "oauth2",
      "baseUrl": "https://api.atlassian.com",
      "timeout": 30000,
      "retryAttempts": 3
    },
    "capabilities": [
      { "capability": "read", "supportedOperations": ["getIssue", "searchIssues", "getProjects"] },
      { "capability": "write", "supportedOperations": ["transitionIssue", "addComment"] }
    ],
    "entityTypes": ["Task", "Person"],
    "freshnessThresholdMs": 300000,
    "metadata": {
      "phase21Package": true,
      "standalonePackage": true,
      "usesKeychain": true,
      "markdownPersistence": true
    }
  },
  "packagePath": "../connector-jira/dist/index.js"
}