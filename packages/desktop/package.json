{
  "name": "@srgnt/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop shell for srgnt",
  "homepage": "https://srgnt.app",
  "author": {
    "name": "srgnt",
    "email": "hello@srgnt.app"
  },
  "main": "./dist/main/index.js",
  "types": "./dist/main/index.d.ts",
  "scripts": {
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "lint": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest run",
    "test:e2e": "pnpm run build && playwright test e2e/app.spec.ts",
    "test:e2e:headed": "pnpm run build && playwright test e2e/app.spec.ts --headed",
    "test:e2e:packaged:linux": "pnpm run pack && playwright test e2e/packaged.spec.ts",
    "dev": "pnpm run build:main && pnpm run build:preload && concurrently -k -n vite,electron \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:electron": "electron .",
    "dev:renderer": "vite",
    "build:icons": "./scripts/build-icons.sh",
    "build": "pnpm run build:main && pnpm run build:preload && pnpm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "pack": "pnpm run build && electron-builder --dir",
    "dist": "pnpm run build && electron-builder",
    "dist:win": "pnpm run build && electron-builder --win",
    "dist:mac": "pnpm run build && electron-builder --mac",
    "dist:linux": "pnpm run build && electron-builder --linux",
    "dist:rpm:fedora": "./scripts/build-fedora-rpm.sh"
  },
  "build": {
    "appId": "app.srgnt",
    "productName": "srgnt",
    "artifactName": "srgnt-${version}-${os}-${arch}.${ext}",
    "extraMetadata": {
      "name": "srgnt"
    },
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "icon.icns"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "maintainer": "srgnt <hello@srgnt.app>",
      "icon": "icons"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@effect/schema": "^0.75.5",
    "@lezer/markdown": "^1.6.3",
    "@srgnt/contracts": "workspace:*",
    "@srgnt/runtime": "workspace:*",
    "codemirror-live-markdown": "0.5.1-alpha.1",
    "effect": "^3.21.0",
    "electron-updater": "^6.3.9",
    "fast-check": "^4.6.0",
    "ghostty-web": "^0.4.0",
    "node-pty": "^1.1.0",
    "pure-rand": "^8.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@srgnt/tsconfig": "workspace:*",
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^15.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "26.8.1",
    "icon-gen": "^5.0.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.8",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "3",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^1.4.0",
    "wait-on": "^9.0.4"
  }
}
