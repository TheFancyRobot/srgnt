{
  "name": "@srgnt/runtime",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first runtime, storage, approvals, and run-history for srgnt",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@effect/schema": "^0.75.5",
    "@huggingface/transformers": "^3.4.0",
    "@srgnt/contracts": "workspace:*",
    "effect": "^3.21.0",
    "vectra": "^0.9.0"
  },
  "devDependencies": {
    "@srgnt/tsconfig": "workspace:*",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
